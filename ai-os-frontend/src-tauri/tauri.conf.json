{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Agent OS",
  "version": "0.1.0",
  "identifier": "tech.virgillito.ai-os",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Agent OS",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/logo.png"],
    "externalBin": []
  }
}